# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexusdb

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme

# TMDB — get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Transcoder — shared secret between api and transcoder service(s)
TRANSCODER_SECRET=changeme

# Path on the Docker host that contains your media files
MEDIA_PATH=/mnt/media

# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
