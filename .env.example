# ── User / Group ──────────────────────────────────────────────────────────────
# Run the server as a specific user so mounted files have the right ownership.
# Find your UID and GID with: id -u  and  id -g
PUID=1000
PGID=1000

# ── App ──────────────────────────────────────────────────────────────────────
# Port the app is exposed on the host
APP_PORT=80

# ── Config path ───────────────────────────────────────────────────────────────
# Host directory where all persistent config is stored:
#   <CONFIG_PATH>/plugins  — your plugin files
#   <CONFIG_PATH>/db       — Postgres data (Option A only)
# Defaults to ./config next to docker-compose.yml if not set.
CONFIG_PATH=./config

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: use the bundled db service (default)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexusdb
DATABASE_URL=postgres://nexus:changeme@db:5432/nexusdb

# Option B: external / self-hosted Postgres — set this and remove the db service
# DATABASE_URL=postgres://user:pass@192.168.1.10:5432/nexusdb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme

# ── TMDB (optional) ───────────────────────────────────────────────────────────
# Get a free key at https://www.themoviedb.org/settings/api
# Can also be set in the web UI under Settings → Metadata
TMDB_API_KEY=

# ── Transcoder ────────────────────────────────────────────────────────────────
# Shared secret between app and all transcoder containers
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRANSCODER_SECRET=changeme
TRANSCODER_NAME=transcoder-cpu

# Hardware acceleration for the external transcoder container.
# Options: cpu (default) | nvenc (NVIDIA) | vaapi (Intel/AMD) | qsv (Intel QuickSync)
HW_ACCEL=cpu

# VAAPI render device path (Linux only, only needed when HW_ACCEL=vaapi or HW_ACCEL=qsv)
# VAAPI_DEVICE=/dev/dri/renderD128

# ── Media ─────────────────────────────────────────────────────────────────────
# Absolute path on the Docker host containing your media files
MEDIA_PATH=/mnt/media

# ── Remote transcoder (only needed on a separate transcoder host) ─────────────
# API_URL=http://<main-server-ip>:80
# TRANSCODER_PUBLIC_URL=http://<this-host>:3001
