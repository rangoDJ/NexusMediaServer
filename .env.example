# ── User / Group ──────────────────────────────────────────────────────────────
# Run the server as a specific user so mounted files have the right ownership.
# Find yours with: id -u  and  id -g
PUID=1000
PGID=1000

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=80

# ── Config path ───────────────────────────────────────────────────────────────
# All persistent server data lives here: plugins, database, and the setup flag.
# Defaults to ./config next to docker-compose.yml if not set.
CONFIG_PATH=./config

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: bundled Postgres (default)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexusdb
DATABASE_URL=postgres://nexus:changeme@db:5432/nexusdb

# Option B: external Postgres — set this and remove the db service from docker-compose.yml
# DATABASE_URL=postgres://user:pass@192.168.1.10:5432/nexusdb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme

# ── TMDB (optional) ───────────────────────────────────────────────────────────
# Can also be entered during the first-launch wizard or set later in Settings → Metadata.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Transcoder ────────────────────────────────────────────────────────────────
# Shared secret between the app and all transcoder containers.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRANSCODER_SECRET=changeme
TRANSCODER_NAME=transcoder-cpu

# Hardware acceleration for the external transcoder container.
# Options: cpu (default) | nvenc (NVIDIA) | vaapi (Intel/AMD) | qsv (Intel QuickSync)
HW_ACCEL=cpu

# VAAPI render device (Linux only, needed when HW_ACCEL=vaapi or HW_ACCEL=qsv)
# VAAPI_DEVICE=/dev/dri/renderD128

# ── Remote transcoder (only needed when running the transcoder on a separate host) ──
# API_URL=http://<main-server-ip>:80
# TRANSCODER_PUBLIC_URL=http://<this-host>:3001
